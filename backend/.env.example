# WireTrust Backend Configuration

# Private key for signing transactions (deployer wallet)
PRIVATE_KEY=

# WireFluid RPC endpoint
WIREFLUID_RPC=https://evm.wirefluid.com
WIREFLUID_WSS=wss://ws.wirefluid.com
WIREFLUID_CHAIN_ID=92533

# Protocol wallets
PROTOCOL_TREASURY=
ORACLE_WALLET=
FRANCHISE_WALLET=

# Server port (defaults to 3001)
PORT=3001

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@host:5432/wiretrust
